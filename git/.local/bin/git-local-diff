#!/bin/sh

base_ref="${1:-develop}"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "error: not a git repository" >&2
  exit 1
fi

if ! git rev-parse --verify --quiet "$base_ref" >/dev/null 2>&1; then
  if ! git show-ref --verify --quiet "refs/heads/$base_ref" \
    && ! git show-ref --verify --quiet "refs/remotes/$base_ref"; then
    echo "error: base ref not found: $base_ref" >&2
    exit 1
  fi
fi

base=$(git merge-base HEAD "$base_ref") || exit 1
diff=$(git diff --no-color "$base"...HEAD)

if [ -z "$diff" ]; then
  echo "no diff between HEAD and $base_ref"
  exit 0
fi

printf "%s\n" "$diff"
